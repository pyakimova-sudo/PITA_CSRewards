<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/account"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Account"
    android:background="@drawable/menu_background">

    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">


    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Custom"
        app:cardBackgroundColor="#C2C5AA"
        android:layout_gravity="center_vertical">

        <LinearLayout
            android:layout_marginTop="30dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rewardPointsText"
                android:fontFamily="@font/ngetic"
                android:gravity="center"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@color/maple_primary"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/points"
                android:fontFamily="@font/ngetic"
                android:gravity="center"
                android:textColor="@color/maple_primary"
                android:textStyle="bold"
                android:textSize="100sp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="227dp"
        android:layout_marginStart="31dp"
        android:layout_gravity="center">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:layout_constraintTop_toTopOf="@id/menus"
                    app:layout_constraintStart_toStartOf="@id/menus"
                    app:layout_constraintEnd_toEndOf="@id/menus"
                    app:srcCompat="@mipmap/ic_launcher"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                    />

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="5dp"/>

                <TextView
                    android:id="@+id/passwordChange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/changePass"
                    android:textSize="15sp"
                    android:padding="10dp"
                    android:background="@drawable/textview_border"
                    app:drawableEndCompat="@drawable/arrow"/>

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="5dp"/>

                <TextView
                    android:id="@+id/phoneChange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/changePhone"
                    android:textSize="15sp"
                    android:padding="10dp"
                    android:background="@drawable/textview_border"
                    app:drawableEndCompat="@drawable/arrow"/>

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="5dp"/>

                <CheckBox
                    android:id="@+id/notification_enable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/notifications"
                    android:background="@drawable/textview_border"
                    android:textSize="15sp"
                    android:padding="10dp"
                    android:checked="false"
                    android:layoutDirection="rtl"/>

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="5dp"/>

                <TextView
                    android:id="@+id/profile_pic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/updatePic"
                    android:textSize="15sp"
                    android:padding="10dp"
                    android:background="@drawable/textview_border"
                    app:drawableEndCompat="@drawable/arrow"/>

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="5dp"/>

                <TextView
                    android:id="@+id/drink_timer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/drinkTimer"
                    android:textSize="15sp"
                    android:padding="10dp"
                    android:background="@drawable/textview_border"
                    app:drawableEndCompat="@drawable/arrow"/>

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="5dp"/>

                <Button
                    android:id="@+id/logout_button"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/logout_button"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/ngetic"
                    android:backgroundTint="@color/maple_secondary"
                    android:textSize="18sp"
                    app:cornerRadius="32dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#C2C5AA"
        app:itemActiveIndicatorStyle="@style/App.Custom.Indicator"
        app:itemIconTint="#414833"
        app:itemTextColor="#414833"
        app:menu="@menu/bottom_navigation_menu" />

</RelativeLayout>