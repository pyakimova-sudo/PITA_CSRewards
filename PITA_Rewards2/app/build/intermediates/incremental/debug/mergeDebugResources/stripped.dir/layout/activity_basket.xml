<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/basket"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Basket"
    android:background="@drawable/menu_background">

    <Button
        android:id="@+id/checkout_button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/checkout_button"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="@font/ngetic"
        android:backgroundTint="@color/maple_secondary"
        android:textSize="18sp"
        app:cornerRadius="32dp"
        android:layout_above="@+id/bottom_navigation"/>


    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:background="#C2C5AA"
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_navigation_menu"
        android:layout_alignParentBottom="true"
        app:itemTextColor="#414833"
        app:itemIconTint="#414833"
        app:itemActiveIndicatorStyle="@style/App.Custom.Indicator"
        android:fitsSystemWindows="true"/>

</RelativeLayout>